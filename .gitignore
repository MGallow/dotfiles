.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Dotfiles — local/personal overrides (never commit these) ──────────────────
git/gitconfig.local.symlink   # contains real name/email — generated by bootstrap

# ── Secrets & credentials (belt-and-suspenders) ───────────────────────────────
.env
.env.*
!.env.example
*.local
.netrc
.aws/
.ssh/
.gnupg/
*.pem
*.key
*.crt
*.p12
*.pfx
*_rsa
*_ed25519
*_ecdsa

# ── Common backup / temp files ────────────────────────────────────────────────
*~
*.bak
*.swp
*.swo
*.old

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
dist/
build/
.venv/
venv/
ENV/

# ── Node / npm ────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
package-lock.json

# ── Git worktrees ─────────────────────────────────────────────────────────────
.worktrees/

# ── Editor directories ────────────────────────────────────────────────────────
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Generated / runtime files ─────────────────────────────────────────────────
