# Gemini CLI aliases

# Core shortcuts
alias gai='gemini'                   # Start Gemini (avoids conflict with Ruby's `gem`)
alias gaip='gemini --prompt'         # One-shot prompt
alias gaic='gemini --sandbox'        # Run in sandbox mode

# Common workflows
alias gaireview='gemini "Review this code for bugs, security issues, and improvements"'
alias gaiexplain='gemini "Explain what this code does in plain language"'
