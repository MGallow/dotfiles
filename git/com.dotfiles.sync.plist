<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.dotfiles.sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>DOTFILES_PLACEHOLDER/git/sync-watch.sh</string>
    </array>

    <!-- Long-running watcher process — restart if it exits unexpectedly -->
    <key>KeepAlive</key>
    <true/>

    <key>RunAtLoad</key>
    <true/>

    <!-- Throttle restarts: wait 10s before restarting a crashed watcher -->
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>HOME_PLACEHOLDER</string>
        <key>DOTFILES</key>
        <string>DOTFILES_PLACEHOLDER</string>
    </dict>

    <key>StandardOutPath</key>
    <string>HOME_PLACEHOLDER/Library/Logs/dotfiles-sync-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>HOME_PLACEHOLDER/Library/Logs/dotfiles-sync-stderr.log</string>

    <key>Nice</key>
    <integer>10</integer>
</dict>
</plist>
