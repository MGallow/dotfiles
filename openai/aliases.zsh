# OpenAI Codex CLI aliases

# Core shortcuts
alias cdx='codex'                    # Start Codex interactive session
alias cdxp='codex --approval-mode full-auto'  # Full auto mode (no approval prompts)
alias cdxq='codex --quiet'           # Quiet mode

# Common workflows
alias cdxreview='codex "Review this code for bugs, security issues, and improvements"'
alias cdxtest='codex "Write comprehensive tests for this code"'
alias cdxfix='codex "Fix any bugs in this code"'
alias cdxdoc='codex "Add docstrings and inline comments to this code"'
alias cdxrefactor='codex "Refactor this code for readability and performance"'
