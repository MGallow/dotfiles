{
  // ── Editor ──────────────────────────────────────────────────────────────────
  "editor.wordWrap": "on",
  "editor.autoClosingBrackets": "always",
  "editor.autoClosingQuotes": "always",
  "editor.find.autoFindInSelection": "multiline",
  "editor.formatOnType": true,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.parameterHints.enabled": false,
  "editor.guides.indentation": false,
  "editor.inlineSuggest.showToolbar": "always",
  "editor.multiCursorLimit": 100000,
  "editor.defaultFormatter": "charliermarsh.ruff",

  // ── Files ────────────────────────────────────────────────────────────────────
  "files.autoSave": "afterDelay",
  "files.autoGuessEncoding": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  // ── Workbench / UI ───────────────────────────────────────────────────────────
  "workbench.colorTheme": "GitHub Dark",
  "workbench.iconTheme": "vscode-icons",
  "workbench.sideBar.location": "right",
  "workbench.startupEditor": "none",
  "workbench.commandPalette.preserveInput": true,
  "workbench.editor.closeOnFileDelete": true,
  "workbench.editor.enablePreview": false,
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "workbench.editor.highlightModifiedTabs": true,
  "window.openFoldersInNewWindow": "off",

  // ── Terminal ─────────────────────────────────────────────────────────────────
  "terminal.external.osxExec": "Hyper.app",
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.enableMultiLinePasteWarning": false,
  "terminal.integrated.inheritEnv": false,
  "terminal.integrated.experimental.aiProfileGrouping": true,

  // ── Search ───────────────────────────────────────────────────────────────────
  "search.showLineNumbers": true,

  // ── Explorer ─────────────────────────────────────────────────────────────────
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,

  // ── Git ──────────────────────────────────────────────────────────────────────
  "git.autofetch": true,
  "git.enableSmartCommit": true,
  "git.fetchOnPull": true,
  "git.confirmSync": false,
  "github.gitProtocol": "ssh",

  // ── GitLens ──────────────────────────────────────────────────────────────────
  "gitlens.blame.ignoreWhitespace": true,

  // ── Merge Conflict ───────────────────────────────────────────────────────────
  "merge-conflict.autoNavigateNextConflict.enabled": true,

  // ── Markdown ─────────────────────────────────────────────────────────────────
  "markdown.preview.breaks": true,
  "markdown.preview.fontSize": 12,

  // ── HTML ─────────────────────────────────────────────────────────────────────
  "html.format.endWithNewline": true,

  // ── Python ───────────────────────────────────────────────────────────────────
  "python.terminal.executeInFileDir": true,
  "python.terminal.shellIntegration.enabled": true,
  "python.analysis.completeFunctionParens": true,
  "python.analysis.addHoverSummaries": true,
  "python.testing.pytestEnabled": true,
  "python.createEnvironment.trigger": "off",
  "python.linting.mypyEnabled": true,
  "python.linting.mypyArgs": [
    "--config-file=${workspaceFolder}/mypy.ini"
  ],
  "python.linting.mypyPath": "mypy",
  "python.linting.mypyCategory": "error",
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports.ruff": "explicit",
      "source.fixAll.ruff": "explicit"
    }
  },

  // ── Ruff ─────────────────────────────────────────────────────────────────────
  "ruff.configurationPreference": "filesystemFirst",
  "ruff.configuration": "",
  "ruff.lint.preview": true,
  "ruff.format.preview": true,

  // ── Notebooks ────────────────────────────────────────────────────────────────
  "notebook.defaultFormatter": "charliermarsh.ruff",
  "notebook.insertFinalNewline": true,
  "notebook.outline.showCodeCells": true,
  "notebook.output.scrolling": true,
  "notebook.output.minimalErrorRendering": true,
  "notebook.output.wordWrap": true,
  "notebook.scrolling.revealNextCellOnExecute": "none",
  "notebook.stickyScroll.enabled": true,
  "notebook.consolidatedRunButton": true,
  "notebook.diff.ignoreMetadata": true,
  "notebook.diff.ignoreOutputs": true,
  "notebook.find.filters": {
    "markupSource": true,
    "markupPreview": true,
    "codeSource": true,
    "codeOutput": true
  },

  // ── Jupyter ──────────────────────────────────────────────────────────────────
  "jupyter.themeMatplotlibPlots": true,

  // ── SQL (MSSQL / PostgreSQL) ──────────────────────────────────────────────────
  "mssql.format.placeSelectStatementReferencesOnNewLine": true,
  "mssql.resultsFontSize": 12,
  "mssql.copyIncludeHeaders": true,
  "mssql.intelliSense.lowerCaseSuggestions": true,
  "pgsql.intelliSense.lowerCaseSuggestions": true,
  "[sql]": {
    "editor.formatOnSave": false
  },

  // ── Snowflake ────────────────────────────────────────────────────────────────
  "snowflake.enableNativeAppPanel": true,

  // ── Docker / Containers ───────────────────────────────────────────────────────
  "docker.containers.label": "ContainerName",
  "docker.containers.description": [
    "CreatedTime",
    "Status"
  ],
  "docker.containers.sortBy": "Label",
  "docker.extension.enableComposeLanguageServer": false,
  "docker.extension.dockerEngineAvailabilityPrompt": false,
  "containers.containers.label": "ContainerName",
  "containers.containers.description": [
    "CreatedTime",
    "Status"
  ],
  "containers.containers.sortBy": "Label",

  // ── Makefile ─────────────────────────────────────────────────────────────────
  "makefile.configureOnOpen": false,

  // ── Miscellaneous Extensions ──────────────────────────────────────────────────
  "vsicons.dontShowNewVersionMessage": true,
  "chatgpt.openOnStartup": true,

  // ── Remote / SSH ─────────────────────────────────────────────────────────────
  "remote.autoForwardPortsSource": "hybrid",
  "remote.SSH.enableAzureIntegration": true,

  // ── Security ─────────────────────────────────────────────────────────────────
  "security.workspace.trust.untrustedFiles": "open",

  // ── GitHub Copilot ────────────────────────────────────────────────────────────
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.chat.welcomeMessage": "never",
  "github.copilot.chat.scopeSelection": true,
  "github.copilot.chat.editor.temporalContext.enabled": true,
  "github.copilot.chat.edits.temporalContext.enabled": true,
  "github.copilot.chat.generateTests.codeLens": true,
  "github.copilot.chat.languageContext.typescript.enabled": true,
  "github.copilot.chat.languageContext.fix.typescript.enabled": true,
  "github.copilot.chat.languageContext.inline.typescript.enabled": true,
  "github.copilot.chat.newWorkspaceCreation.enabled": true,
  "github.copilot.chat.search.semanticTextResults": true,
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.chat.codeGeneration.instructions": [],
  "github.copilot.chat.completionContext.typescript.mode": "on",
  "github.copilot.chat.agent.thinkingTool": true,
  "github.copilot.chat.notebook.followCellExecution.enabled": true,
  "github.copilot.chat.customInstructionsInSystemMessage": true,
  "github.copilot.chat.anthropic.tools.websearch.enabled": true,
  "github.copilot.chat.anthropic.tools.websearch.maxUses": 20,

  // ── GitHub Pull Requests ──────────────────────────────────────────────────────
  "githubPullRequests.pullRequestDescription": "Copilot",
  "githubPullRequests.pushBranch": "always",
  "githubPullRequests.pullBranch": "always",
  "githubPullRequests.notifications": "pullRequests",
  "githubPullRequests.codingAgent.uiIntegration": true,
  "githubPullRequests.codingAgent.autoCommitAndPush": false,
  "githubPullRequests.experimental.useQuickChat": true,

  // ── GitHub Issues ─────────────────────────────────────────────────────────────
  "githubIssues.assignWhenWorking": false,

  // ── Gemini Code Assist ────────────────────────────────────────────────────────
  "geminicodeassist.updateChannel": "Insiders",
  "geminicodeassist.enableTelemetry": false,
  "geminicodeassist.inlineSuggestions.suggestionSpeed": "Fast",
  "geminicodeassist.codeGenerationPaneViewEnabled": true,
  "geminicodeassist.displayInlineContextHint": false,

  // ── Claude Code ───────────────────────────────────────────────────────────────
  "claudeCode.initialPermissionMode": "acceptEdits",

  // ── Chat / Agent ──────────────────────────────────────────────────────────────
  "chat.agent.maxRequests": 1000,
  "chat.tools.terminal.outputLocation": "chat",
  "chat.hookFilesLocations": {
    ".github/hooks": true,
    ".claude/settings.local.json": true,
    ".claude/settings.json": true,
    "~/.copilot/hooks": true,
    "~/.claude/settings.json": true,
    "~/.agents/hooks": true
  },
  "chat.useClaudeHooks": true,
  "chat.mcp.discovery.enabled": {
    "claude-desktop": true,
    "windsurf": true,
    "cursor-global": true,
    "cursor-workspace": true
  },
  "chat.tools.urls.autoApprove": {
    "https://docs.snowflake.com": {
      "approveRequest": false,
      "approveResponse": true
    }
  },
  "chat.tools.terminal.autoApprove": {
    "mkdir": true,
    "cd": true,
    "touch": true,
    "cp": true,
    "echo": true,
    "ls": true,
    "pwd": true,
    "cat": true,
    "head": true,
    "tail": true,
    "findstr": true,
    "wc": true,
    "tr": true,
    "cut": true,
    "cmp": true,
    "which": true,
    "basename": true,
    "dirname": true,
    "realpath": true,
    "readlink": true,
    "stat": true,
    "file": true,
    "du": true,
    "df": true,
    "sleep": true,
    "uv run pytest": true,
    "pytest": true,
    "uv run ruff": true,
    "ruff": true,
    "uv run mypy": true,
    "mypy": true,
    "uv run python": true,
    "git status": true,
    "git log": true,
    "git show": true,
    "git diff": true,
    "Get-ChildItem": true,
    "Get-Date": true,
    "Get-Random": true,
    "Get-Location": true,
    "Write-Host": true,
    "Write-Output": true,
    "Split-Path": true,
    "Join-Path": true,
    "Start-Sleep": true,
    "/^Select-[a-z0-9]/i": true,
    "/^Measure-[a-z0-9]/i": true,
    "/^Compare-[a-z0-9]/i": true,
    "/^Format-[a-z0-9]/i": true,
    "/^Sort-[a-z0-9]/i": true,
    "column": true,
    "/^column\\b.*-c\\s+[0-9]{4,}/": false,
    "date": true,
    "/^date\\b.*(-s|--set)\\b/": false,
    "find": true,
    "/^find\\b.*-(delete|exec|execdir|fprint|fprintf|fls)\\b/": false,
    "grep": true,
    "/^grep\\b.*-(f|P)\\b/": false,
    "sort": true,
    "/^sort\\b.*-(o|S)\\b/": false,
    "tree": true,
    "/^tree\\b.*-o\\b/": false,
    "/\\(.+\\)/": {
      "approve": false,
      "matchCommandLine": true
    },
    "/\\{.+\\}/": {
      "approve": false,
      "matchCommandLine": true
    },
    "/`.+`/": {
      "approve": false,
      "matchCommandLine": true
    },
    "rm": false,
    "rmdir": false,
    "del": false,
    "Remove-Item": false,
    "ri": false,
    "rd": false,
    "erase": false,
    "dd": false,
    "kill": false,
    "ps": false,
    "top": false,
    "Stop-Process": false,
    "spps": false,
    "taskkill": false,
    "taskkill.exe": false,
    "curl": false,
    "wget": false,
    "Invoke-RestMethod": false,
    "Invoke-WebRequest": false,
    "irm": false,
    "iwr": false,
    "chmod": false,
    "chown": false,
    "Set-ItemProperty": false,
    "sp": false,
    "Set-Acl": false,
    "jq": false,
    "xargs": false,
    "eval": false,
    "Invoke-Expression": false,
    "iex": false
  }
}
