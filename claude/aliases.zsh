# Claude Code aliases

# Core shortcuts
alias cl='claude'                    # Start Claude Code
alias clc='claude --continue'        # Continue the last conversation
alias clp='claude --print'           # Non-interactive: print response to stdout
alias clr='claude --resume'          # Resume a specific conversation

# Common workflows
alias clcommit='claude "Review my staged git changes and write a commit message"'
alias clreview='claude "Review this code for bugs, security issues, and improvements"'
alias cltest='claude "Write tests for the selected code"'
alias cldoc='claude "Add docstrings and comments to this code"'
