#!/usr/bin/env bash
#
# Run all dotfiles installers.

set -e

cd "$(dirname "$0")"/..

info()    { printf "\r  [ \033[00;34m..\033[0m ] %s\n" "$1"; }
success() { printf "\r\033[2K  [ \033[00;32mOK\033[0m ] %s\n" "$1"; }

# ── 1. Homebrew ──────────────────────────────────────────────────────────────
info "Installing Homebrew dependencies"
"$HOME/.dotfiles/homebrew/install.sh" 2>&1
success "Homebrew dependencies installed"

# ── 2. Oh My Zsh + plugins ───────────────────────────────────────────────────
# Canonical installer lives in zsh/install.sh (used standalone and here).
# RUNZSH=no and CHSH=no are already set inside zsh/install.sh.
info "Installing Oh My Zsh and plugins"
bash "${DOTFILES:-$HOME/.dotfiles}/zsh/install.sh"
success "Oh My Zsh and plugins ready"

# ── 4. Topic installers (priority-ordered) ───────────────────────────────────
# Topics with an install.priority file run in that order (lower = earlier).
# Topics without one default to priority 50. Adding a new topic requires
# only an install.sh in its directory; no edits to this file are needed.
info "Running topic installers"

tmp_list=$(mktemp)

while IFS= read -r installer; do
    topic_dir="$(dirname "$installer")"
    priority_file="$topic_dir/install.priority"
    if [ -f "$priority_file" ]; then
        priority="$(cat "$priority_file")"
    else
        priority=50
    fi
    printf '%s %s\n' "$priority" "$installer" >> "$tmp_list"
done < <(find . -maxdepth 2 -name install.sh \
    -not -path "./script/*" \
    -not -path "./homebrew/*")

while IFS= read -r line; do
    installer="${line#* }"
    priority="${line%% *}"
    topic="$(basename "$(dirname "$installer")")"
    info "Running $topic installer (priority $priority)"
    bash "$installer"
    success "$topic setup complete"
done < <(sort -n "$tmp_list")

rm -f "$tmp_list"

# ── 5. macOS defaults ─────────────────────────────────────────────────────────
if [ "$(uname -s)" = "Darwin" ]; then
    info "Setting macOS defaults"
    "$HOME/.dotfiles/macos/set-defaults.sh"
    success "macOS defaults applied"
fi

# ── 6. Local config stubs ─────────────────────────────────────────────────────
info "Creating local config stubs"
touch "$HOME/.zshrc.local"
touch "$HOME/.gitconfig.local"

# Seed .zshrc.local with stubs if it's empty
if [ ! -s "$HOME/.zshrc.local" ]; then
    cat >> "$HOME/.zshrc.local" <<'EOF'
# ── AI API Keys ───────────────────────────────────────────────────────────────
# Claude Code and Gemini CLI use browser-based sign-in — no key needed.
# Codex CLI (OpenAI) requires an API key; add it here if using Codex.
# export OPENAI_API_KEY=""      # https://platform.openai.com/api-keys

# ── Local overrides ───────────────────────────────────────────────────────────
EOF
fi
success "Local config stubs ready"

echo ""
echo "  ✓ All installations complete!"
echo ""
echo "  Next steps:"
echo "    1. Open a new terminal (or run: source ~/.zshrc)"
echo "    2. Authenticate GitHub CLI:  gh auth login"
echo "    3. Sign in to Claude Code:    claude  (browser opens automatically)"
echo "    4. Sign in to Gemini CLI:     gemini  (browser opens automatically)"
echo "    5. Codex (OpenAI) API key:    add OPENAI_API_KEY to ~/.zshrc.local"
echo ""
