#!/usr/bin/env bash
#
# Verify the dotfiles installation is healthy.
# Run this after ./script/install to confirm everything is in place.
# Exit code 0 = all checks passed. Non-zero = one or more checks failed.

PASS=0
FAIL=0
WARN=0

green='\033[0;32m'
red='\033[0;31m'
yellow='\033[0;33m'
reset='\033[0m'

ok()   { printf "  ${green}✓${reset}  %s\n" "$1"; PASS=$((PASS+1)); }
fail() { printf "  ${red}✗${reset}  %s\n" "$1"; FAIL=$((FAIL+1)); }
warn() { printf "  ${yellow}~${reset}  %s\n" "$1"; WARN=$((WARN+1)); }
header() { printf "\n${reset}%s\n" "$1"; }

# ── Symlinks ──────────────────────────────────────────────────────────────────
header "Symlinks"
for pair in \
    "$HOME/.zshrc:zsh/zshrc.symlink" \
    "$HOME/.gitconfig:git/gitconfig.symlink" \
    "$HOME/.gitignore:git/gitignore.symlink" \
    "$HOME/.vimrc:vim/vimrc.symlink" \
    "$HOME/.tmux.conf:tmux/tmux.conf.symlink"
do
    link="${pair%%:*}"
    src="${pair##*:}"
    if [ -L "$link" ]; then
        ok "$link → $(readlink "$link")"
    else
        fail "$link (expected symlink, got: $(ls -ld "$link" 2>/dev/null | awk '{print $1}' || echo 'missing'))"
    fi
done

# ── Core CLI tools ────────────────────────────────────────────────────────────
header "Core CLI tools"
for tool in brew git zsh node npm uv ruff; do
    if command -v "$tool" &>/dev/null; then
        ok "$tool  $(command -v "$tool")"
    else
        fail "$tool  not found"
    fi
done

# ── GitHub CLI ────────────────────────────────────────────────────────────────
header "GitHub CLI"
if command -v gh &>/dev/null; then
    ok "gh  $(gh --version | head -1)"
    if gh auth status &>/dev/null; then
        ok "gh auth  $(gh auth status 2>&1 | grep 'Logged in' | xargs)"
    else
        warn "gh auth  not authenticated — run: gh auth login"
    fi
    if gh extension list 2>/dev/null | grep -q "github/gh-copilot"; then
        ok "gh-copilot extension installed"
    else
        warn "gh-copilot extension missing — run: gh extension install github/gh-copilot"
    fi
else
    fail "gh  not found — run: brew install gh"
fi

# ── AI CLIs ───────────────────────────────────────────────────────────────────
header "AI CLIs"

if command -v claude &>/dev/null; then
    ok "claude  $(claude --version 2>/dev/null || echo 'installed')"
    # Check if authenticated (claude outputs to stderr on unauthed)
    if claude --print "ping" &>/dev/null 2>&1; then
        ok "claude auth  authenticated"
    else
        warn "claude auth  not authenticated — run: claude"
    fi
else
    fail "claude  not found — run: npm install -g @anthropic-ai/claude-code"
fi

if command -v gemini &>/dev/null; then
    ok "gemini  installed"
else
    fail "gemini  not found — run: npm install -g @google/gemini-cli"
fi

if command -v codex &>/dev/null; then
    ok "codex  installed"
    if [ -z "$OPENAI_API_KEY" ]; then
        warn "OPENAI_API_KEY  not set — add to ~/.zshrc.local to use Codex"
    else
        ok "OPENAI_API_KEY  set"
    fi
else
    warn "codex  not installed — optional, run: npm install -g @openai/codex"
fi

# ── Python / conda ────────────────────────────────────────────────────────────
header "Python / conda / uv"
if command -v conda &>/dev/null; then
    ok "conda  $(conda --version)"
else
    fail "conda  not found — miniconda may not be initialized. Run: conda init zsh"
fi

if command -v uv &>/dev/null; then
    ok "uv  $(uv --version)"
else
    fail "uv  not found — run: brew install uv"
fi

if command -v ruff &>/dev/null; then
    ok "ruff  $(ruff --version)"
else
    fail "ruff  not found — run: uv pip install ruff  (in active conda env)"
fi

if command -v pre-commit &>/dev/null; then
    ok "pre-commit  $(pre-commit --version)"
else
    warn "pre-commit  not found in PATH (install in each project: uv pip install pre-commit)"
fi

# ── VS Code Insiders ──────────────────────────────────────────────────────────
header "VS Code Insiders"
if command -v code-insiders &>/dev/null; then
    ok "code-insiders  $(code-insiders --version 2>/dev/null | head -1)"

    settings_dir="$HOME/Library/Application Support/Code - Insiders/User"
    if [ -L "$settings_dir/settings.json" ]; then
        ok "settings.json  symlinked"
    else
        warn "settings.json  not symlinked — run: ~/.dotfiles/vscode/install.sh"
    fi

    if code-insiders --list-extensions 2>/dev/null | grep -q "charliermarsh.ruff"; then
        ok "ruff extension  installed"
    else
        warn "ruff extension  missing — run: code-insiders --install-extension charliermarsh.ruff"
    fi
    if code-insiders --list-extensions 2>/dev/null | grep -q "github.copilot"; then
        ok "copilot extension  installed"
    else
        warn "copilot extension  missing — run: ~/.dotfiles/vscode/install.sh"
    fi
else
    warn "code-insiders  not found (VS Code Insiders not installed or not on PATH)"
fi

# ── Oh My Zsh ─────────────────────────────────────────────────────────────────
header "Oh My Zsh"
if [ -d "$HOME/.oh-my-zsh" ]; then
    ok "oh-my-zsh  $HOME/.oh-my-zsh"
    ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"
    for plugin in zsh-autosuggestions zsh-syntax-highlighting; do
        if [ -d "$ZSH_CUSTOM/plugins/$plugin" ]; then
            ok "plugin $plugin"
        else
            fail "plugin $plugin missing — run: ./script/install"
        fi
    done
else
    fail "oh-my-zsh  not installed — run: ./script/install"
fi

# ── Local config stubs ────────────────────────────────────────────────────────
header "Local config stubs"
for f in "$HOME/.zshrc.local" "$HOME/.gitconfig.local"; do
    if [ -f "$f" ]; then
        ok "$f  exists"
    else
        warn "$f  missing — run: ./script/install"
    fi
done

# ── Shell sanity check ────────────────────────────────────────────────────────
header "Shell sanity"
if zsh -c 'source ~/.zshrc 2>&1' | grep -qi "error\|command not found" 2>/dev/null; then
    warn "~/.zshrc  loaded with warnings — check output of: zsh -c 'source ~/.zshrc'"
else
    ok "~/.zshrc  loads cleanly"
fi

# ── Summary ───────────────────────────────────────────────────────────────────
echo ""
echo "──────────────────────────────────────────"
printf "  ${green}✓${reset} %d passed   " "$PASS"
if [ "$WARN" -gt 0 ]; then
    printf "${yellow}~${reset} %d warnings   " "$WARN"
fi
if [ "$FAIL" -gt 0 ]; then
    printf "${red}✗${reset} %d failed" "$FAIL"
fi
echo ""
echo "──────────────────────────────────────────"
echo ""

if [ "$FAIL" -gt 0 ]; then
    exit 1
fi
exit 0
