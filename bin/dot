#!/bin/sh
#
# dot
#
# `dot` handles installation, updates, things like that. Run it periodically
# to make sure you're on the latest and greatest.

set -e

parentDirectory="$(cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd -P)"
dotfilesDirectory="$(cd "$( dirname "$parentDirectory" )" && pwd -P)"

displayUsageAndExit() {
    echo "dot -- dotfiles management"
    echo ""
    echo "Usage: dot [options]"
    echo ""
    echo "Options:"
    echo "  -e, --edit    Open dotfiles directory for editing in VS Code"
    echo "  -h, --help    Show this help message and exit"
    echo "  update        Update packages, AI tools, and pkg managers"
    echo "  sync          Run a one-off sync with remote now"
    echo "  sync-on       Enable automatic background sync (fswatch + launchd)"
    echo "  sync-off      Disable automatic background sync"
    echo "  sync-status   Show whether auto-sync is running"
    echo "  sync-log      Tail the sync log"
    exit
}

while test $# -gt 0; do
    case "$1" in
        "-h"|"--help")
            displayUsageAndExit
            ;;
        "-e"|"--edit")
            exec code "$dotfilesDirectory"
            exit
            ;;
        "sync")
            echo "› Running one-off dotfiles sync…"
            bash "$dotfilesDirectory/git/sync.sh"
            echo "✓ Sync complete — check ~/Library/Logs/dotfiles-sync.log"
            exit
            ;;
        "sync-on")
            # Ensure fswatch is installed
            if ! command -v fswatch &>/dev/null; then
                echo "› fswatch not found — installing via Homebrew…"
                brew install fswatch
            fi
            plist_src="$dotfilesDirectory/git/com.dotfiles.sync.plist"
            plist_dst="$HOME/Library/LaunchAgents/com.dotfiles.sync.plist"
            # Render placeholders
            sed -e "s|DOTFILES_PLACEHOLDER|$dotfilesDirectory|g" \
                -e "s|HOME_PLACEHOLDER|$HOME|g" \
                "$plist_src" > "$plist_dst"
            launchctl unload "$plist_dst" 2>/dev/null || true
            launchctl load "$plist_dst"
            echo "✓ Auto-sync enabled (fswatch — syncs within seconds of file changes)"
            echo "  Also pulls from remote every 5 min"
            echo "  Plist: $plist_dst"
            echo "  Log:   ~/Library/Logs/dotfiles-sync.log"
            exit
            ;;
        "sync-off")
            plist_dst="$HOME/Library/LaunchAgents/com.dotfiles.sync.plist"
            if [ -f "$plist_dst" ]; then
                launchctl unload "$plist_dst" 2>/dev/null || true
                rm -f "$plist_dst"
                echo "✓ Auto-sync disabled"
            else
                echo "Auto-sync is not enabled"
            fi
            exit
            ;;
        "sync-status")
            if launchctl list com.dotfiles.sync &>/dev/null; then
                pid=$(launchctl list com.dotfiles.sync 2>/dev/null | awk 'NR==2{print $1}')
                echo "✓ Auto-sync is ACTIVE (fswatch watcher${pid:+, pid $pid})"
                echo "  Last 5 log entries:"
                tail -5 "$HOME/Library/Logs/dotfiles-sync.log" 2>/dev/null || echo "  (no log yet)"
            else
                echo "✗ Auto-sync is NOT running"
                echo "  Enable with: dot sync-on"
            fi
            exit
            ;;
        "sync-log")
            tail -30 "$HOME/Library/Logs/dotfiles-sync.log" 2>/dev/null || echo "No sync log found"
            exit
            ;;
        "update")
            if [ "$(uname -s)" = "Darwin" ]; then
                # Update Homebrew
                echo "› brew update"
                brew update
                echo "› brew upgrade"
                brew upgrade
                echo "› brew cleanup"
                brew cleanup
            fi

            # Update Oh My Zsh
            echo "› updating oh-my-zsh"
            /bin/sh "$ZSH/tools/upgrade.sh"

            # Update dotfiles
            echo "› git pull origin main"
            cd "$dotfilesDirectory" || exit
            git pull origin main

            # Update AI CLIs installed via npm
            if command -v npm &>/dev/null; then
                echo "› updating Claude Code CLI"
                npm update -g @anthropic-ai/claude-code 2>/dev/null || true

                echo "› updating Gemini CLI"
                npm update -g @google/gemini-cli 2>/dev/null || true

                echo "› updating OpenAI Codex CLI"
                npm update -g @openai/codex 2>/dev/null || true
            fi

            # Update uv
            if command -v uv &>/dev/null; then
                echo "› updating uv"
                brew upgrade uv 2>/dev/null || true
            fi

            # Update GitHub Copilot CLI extension
            if command -v gh &>/dev/null; then
                echo "› updating gh extensions"
                gh extension upgrade --all 2>/dev/null || true
            fi

            # Update all VS Code extensions
            echo "› updating VS Code extensions"
            code --list-extensions | xargs -L 1 code --install-extension
            if command -v code-insiders &>/dev/null; then
                code-insiders --list-extensions | xargs -L 1 code-insiders --install-extension
            fi

            exit
            ;;
        *)
            echo "Invalid option: $1"
            displayUsageAndExit
            ;;
    esac
    shift
done

export ZSH=$HOME/.oh-my-zsh

# Install homebrew
"$dotfilesDirectory/homebrew/install.sh" 2>&1

# Upgrade homebrew
echo "› brew update"
brew update

# Install software
echo "› $dotfilesDirectory/script/install"
"$dotfilesDirectory/script/install"
