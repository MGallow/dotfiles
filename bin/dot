#!/bin/sh
#
# dot
#
# `dot` handles installation, updates, things like that. Run it periodically
# to make sure you're on the latest and greatest.

set -e

parentDirectory="$(cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd -P)"
dotfilesDirectory="$(cd "$( dirname "$parentDirectory" )" && pwd -P)"

displayUsageAndExit() {
    echo "dot -- dotfiles management"
    echo ""
    echo "Usage: dot [options]"
    echo ""
    echo "Options:"
    echo "  -e, --edit    Open dotfiles directory for editing in VS Code"
    echo "  -h, --help    Show this help message and exit"
    echo "  update        Update packages, AI tools, and pkg managers"
    echo "  sync          Sync dotfiles with remote (pull, commit, push)"
    exit
}

while test $# -gt 0; do
    case "$1" in
        "-h"|"--help")
            displayUsageAndExit
            ;;
        "-e"|"--edit")
            exec code "$dotfilesDirectory"
            exit
            ;;
        "sync")
            echo "› Syncing dotfiles with remote…"
            bash "$dotfilesDirectory/git/sync.sh"
            echo "✓ Sync complete"
            exit
            ;;
        "sync-on")
            plist_dst="$HOME/Library/LaunchAgents/com.dotfiles.sync.plist"
            sync_script="$HOME/.local/bin/dotfiles-sync.sh"
            mkdir -p "$HOME/.local/bin"

            # Generate sync script at runtime from terminal context
            # (avoids macOS provenance restrictions on repo files)
            cat > "$sync_script" <<'SYNCEOF'
#!/usr/bin/env bash
set -euo pipefail
LOGFILE="$HOME/Library/Logs/dotfiles-sync.log"
BRANCH="main"
REMOTE="origin"
mkdir -p "$(dirname "$LOGFILE")"
log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOGFILE"; }
cd "$DOTFILES" || { log "ERROR: Cannot cd to $DOTFILES"; exit 1; }
git rev-parse --is-inside-work-tree &>/dev/null || { log "ERROR: Not a git repo"; exit 1; }
current_branch=$(git symbolic-ref --short HEAD 2>/dev/null)
[[ "$current_branch" == "$BRANCH" ]] || { log "SKIP: On branch '$current_branch'"; exit 0; }
[[ ! -d .git/rebase-merge && ! -d .git/rebase-apply && ! -f .git/MERGE_HEAD ]] || { log "SKIP: Rebase/merge in progress"; exit 0; }
host github.com &>/dev/null || { log "SKIP: Offline"; exit 0; }
log "Starting sync..."
git fetch "$REMOTE" "$BRANCH" --quiet 2>/dev/null || { log "SKIP: Fetch failed"; exit 0; }
local_sha=$(git rev-parse HEAD)
remote_sha=$(git rev-parse "$REMOTE/$BRANCH")
base_sha=$(git merge-base HEAD "$REMOTE/$BRANCH")
if [[ "$local_sha" != "$remote_sha" && "$local_sha" == "$base_sha" ]]; then
    git merge --ff-only "$REMOTE/$BRANCH" --quiet 2>/dev/null && log "PULLED: Fast-forwarded" || { log "SKIP: FF merge failed"; exit 0; }
elif [[ "$local_sha" != "$remote_sha" && "$remote_sha" != "$base_sha" && "$local_sha" != "$base_sha" ]]; then
    log "SKIP: Diverged — manual merge needed"; exit 0
fi
git add -A
if ! git diff --cached --quiet; then
    changed=$(git diff --cached --name-only)
    count=$(echo "$changed" | wc -l | tr -d ' ')
    first=$(echo "$changed" | head -1)
    [[ "$count" -eq 1 ]] && msg="auto-sync: update $first" || msg="auto-sync: update $first (+$((count - 1)) more)"
    git commit -m "$msg" --quiet
    log "COMMITTED: $msg"
fi
local_sha=$(git rev-parse HEAD)
remote_sha=$(git rev-parse "$REMOTE/$BRANCH")
if [[ "$local_sha" != "$remote_sha" ]]; then
    git push "$REMOTE" "$BRANCH" --quiet 2>/dev/null && log "PUSHED: to $REMOTE/$BRANCH" || log "ERROR: Push failed"
else
    log "OK: Already in sync"
fi
SYNCEOF
            chmod +x "$sync_script"

            # Generate plist with WatchPaths + timer
            cat > "$plist_dst" <<PLISTEOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.dotfiles.sync</string>
    <key>ProgramArguments</key>
    <array>
        <string>$sync_script</string>
    </array>
    <key>WatchPaths</key>
    <array>
        <string>$dotfilesDirectory</string>
    </array>
    <key>StartInterval</key>
    <integer>300</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>10</integer>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>$HOME</string>
        <key>DOTFILES</key>
        <string>$dotfilesDirectory</string>
    </dict>
    <key>StandardOutPath</key>
    <string>$HOME/Library/Logs/dotfiles-sync-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>$HOME/Library/Logs/dotfiles-sync-stderr.log</string>
    <key>Nice</key>
    <integer>10</integer>
</dict>
</plist>
PLISTEOF
            launchctl unload "$plist_dst" 2>/dev/null || true
            launchctl load "$plist_dst"
            echo "✓ Auto-sync enabled (launchd WatchPaths + 5-min remote poll)"
            echo "  Syncs on local file changes and pulls remote every 5 min"
            echo "  Plist: $plist_dst"
            echo "  Script: $sync_script"
            echo "  Log:   ~/Library/Logs/dotfiles-sync.log"
            exit
            ;;
        "sync-off")
            plist_dst="$HOME/Library/LaunchAgents/com.dotfiles.sync.plist"
            if [ -f "$plist_dst" ]; then
                launchctl unload "$plist_dst" 2>/dev/null || true
                rm -f "$plist_dst"
                echo "✓ Auto-sync disabled"
            else
                echo "Auto-sync is not enabled"
            fi
            exit
            ;;
        "sync-status")
            if launchctl list com.dotfiles.sync &>/dev/null; then
                echo "✓ Auto-sync is ACTIVE (launchd WatchPaths + timer)"
                echo "  Last 5 log entries:"
                tail -5 "$HOME/Library/Logs/dotfiles-sync.log" 2>/dev/null || echo "  (no log yet)"
            else
                echo "✗ Auto-sync is NOT running"
                echo "  Enable with: dot sync-on"
            fi
            exit
            ;;
        "sync-log")
            tail -30 "$HOME/Library/Logs/dotfiles-sync.log" 2>/dev/null || echo "No sync log found"
            exit
            ;;
        "update")
            if [ "$(uname -s)" = "Darwin" ]; then
                # Update Homebrew
                echo "› brew update"
                brew update
                echo "› brew upgrade"
                brew upgrade
                echo "› brew cleanup"
                brew cleanup
            fi

            # Update Oh My Zsh
            echo "› updating oh-my-zsh"
            /bin/sh "$ZSH/tools/upgrade.sh"

            # Update dotfiles
            echo "› git pull origin main"
            cd "$dotfilesDirectory" || exit
            git pull origin main

            # Update AI CLIs installed via npm
            if command -v npm &>/dev/null; then
                echo "› updating Claude Code CLI"
                npm update -g @anthropic-ai/claude-code 2>/dev/null || true

                echo "› updating Gemini CLI"
                npm update -g @google/gemini-cli 2>/dev/null || true

                echo "› updating OpenAI Codex CLI"
                npm update -g @openai/codex 2>/dev/null || true
            fi

            # Update uv
            if command -v uv &>/dev/null; then
                echo "› updating uv"
                brew upgrade uv 2>/dev/null || true
            fi

            # Update GitHub Copilot CLI extension
            if command -v gh &>/dev/null; then
                echo "› updating gh extensions"
                gh extension upgrade --all 2>/dev/null || true
            fi

            # Update all VS Code extensions
            echo "› updating VS Code extensions"
            code --list-extensions | xargs -L 1 code --install-extension
            if command -v code-insiders &>/dev/null; then
                code-insiders --list-extensions | xargs -L 1 code-insiders --install-extension
            fi

            exit
            ;;
        *)
            echo "Invalid option: $1"
            displayUsageAndExit
            ;;
    esac
    shift
done

export ZSH=$HOME/.oh-my-zsh

# Install homebrew
"$dotfilesDirectory/homebrew/install.sh" 2>&1

# Upgrade homebrew
echo "› brew update"
brew update

# Install software
echo "› $dotfilesDirectory/script/install"
"$dotfilesDirectory/script/install"
