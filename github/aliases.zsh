# GitHub CLI aliases

# GitHub Copilot CLI
alias ghcs='gh copilot suggest'      # Ask Copilot to suggest a command
alias ghce='gh copilot explain'      # Ask Copilot to explain a command

# Pull requests
alias ghprc='gh pr create'           # Create a pull request
alias ghprl='gh pr list'             # List pull requests
alias ghprv='gh pr view'             # View a pull request
alias ghprm='gh pr merge'            # Merge a pull request
alias ghprs='gh pr status'           # Check PR status

# Issues
alias ghic='gh issue create'         # Create an issue
alias ghil='gh issue list'           # List issues
alias ghiv='gh issue view'           # View an issue

# Repos
alias ghrc='gh repo clone'           # Clone a repo
alias ghrv='gh repo view'            # View a repo in the browser
alias ghrf='gh repo fork'            # Fork a repo

# Workflows / Actions
alias ghwl='gh run list'             # List workflow runs
alias ghwv='gh run view'             # View a workflow run
alias ghww='gh run watch'            # Watch a running workflow
